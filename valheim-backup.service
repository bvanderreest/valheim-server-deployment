[Unit]
Description=Valheim Server Backup Service
After=network.target

[Service]
Type=oneshot
# User and ExecStart are substituted by 'deploy' — do not edit this file directly.
User=__USER__
ExecStart=__SCRIPT_DIR__/backup-automation.sh
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target