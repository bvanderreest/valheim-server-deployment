# Valheim Server Configuration Example
# This file contains example configurations that can be copied to .env
# DO NOT commit .env files to version control - they contain sensitive data

# Identity & Server Name
SERVER_NAME="My Valheim Server"
WORLD_NAME="MyWorld"
PASSWORD="serverpassword123"

# Networking
PORT=2456
PUBLIC=1
CROSSPLAY=true

# Installation Paths
# Default for deploy command is: /path/to/script/server/
SERVER_DIR="${SCRIPT_DIR}/server"

# Data, Logs & Backups
SAVEDIR="/srv/valheim/worlds"
LOG_DIR="/srv/valheim/logs"
LOGFILE="${LOG_DIR}/valheim-server.log"
PIDFILE="/srv/valheim/valheim.pid"
BACKUP_DIR="/srv/valheim/backups"

# Resilience & Backups
SAVE_INTERVAL=300
BACKUPS_KEEP=12
BACKUP_SHORT=900
BACKUP_LONG=3600

# SteamCMD Update
USE_STEAMCMD_UPDATE=true
STEAMCMD_BIN="/usr/games/steamcmd"
STEAM_LOGIN="anonymous"

# Custom arguments (optional)
# ENABLE_CUSTOM_ARGS=false
# CUSTOM_ARGS=()

# ─── Management API ────────────────────────────────────────────────────────────
# Set API_ENABLED=true to allow the API to start. Default is false (disabled).
# Use api-manager.sh or the systemd service (api/valheim-api.service) to manage the process.
API_ENABLED=false

# Network binding for the API (loopback only is recommended; put nginx in front for HTTPS)
API_HOST=127.0.0.1
API_PORT=8080

# API keys — comma-separated. All authenticated endpoints require X-API-Key: <key>.
# Generate a key: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEYS=""

# CORS origins allowed to call the API — comma-separated, or * for any origin.
# Set this to your dashboard's domain in production.
CORS_ORIGINS="*"

# Server identity — returned in every response so the dashboard knows which server this is.
SERVER_TYPE="valheim"
SERVER_LABEL="My Valheim Server"