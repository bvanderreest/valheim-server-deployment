# Valheim Server Manager - .gitignore

# Environment files
.env
.env.*
  
# Modifier configuration files (user-specific, not for version control)
modifiers.conf
 
# Backup files
*.bak
*.backup
 
# OS generated files
.DS_Store
Thumbs.db
 
# IDE
.vscode/
.idea/
*.swp
*.swo
 
# System
*.tmp
*.temp
*.log
*.logs

# Valheim server directory (do not commit binaries)
server/

# Management API — runtime files
.api.pid
.api.log
.venv/
.env.local
.env.*.local
.swarm/

# Claude Code tooling — excluded from public GitHub mirror
CLAUDE.md
.claude/
.mcp.json
.claude-flow/
